# ─── App ─────────────────────────────────────────────────────────────────────

# Application port (optional, default: 3000)
PORT=3000

# Environment (optional, default: development)
NODE_ENV="development"

# Enable Swagger UI — never enable in production (optional, default: false)
SWAGGER_ENABLED="true"

# ─── Database ─────────────────────────────────────────────────────────────────

# PostgreSQL connection URL
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/linked_me?schema=public"

# ─── Auth / JWT ───────────────────────────────────────────────────────────────

# Secret used to sign JWT access tokens
JWT_SECRET="change-me"

# Access token lifetime (optional, default: 15m)
JWT_ACCESS_EXPIRY="15m"

# Secret used to sign refresh tokens (must differ from JWT_SECRET)
JWT_REFRESH_SECRET="change-me-refresh"

# Refresh token lifetime (optional, default: 7d)
JWT_REFRESH_EXPIRY="7d"

# ─── URLs ─────────────────────────────────────────────────────────────────────

# API base URL used to build links in emails (optional, default: http://localhost:3000)
APP_URL="http://localhost:3000"

# Frontend URL for the password reset link in emails (optional, falls back to APP_URL)
FRONTEND_URL="https://app.your-domain.com"

# CORS allowed origin (optional, default: all origins allowed)
CORS_ORIGIN="https://your-frontend.com"

# Allowed origins for callbackUrl, comma-separated (optional, default: callbackUrl rejected)
ALLOWED_REDIRECT_ORIGINS="https://app.your-domain.com,http://localhost:4200"

# ─── Email ────────────────────────────────────────────────────────────────────

# Resend API key (email sending service)
RESEND_API_KEY="re_xxxxx"

# Sender email address — must be verified in Resend (optional, default: onboarding@resend.dev)
MAIL_FROM="onboarding@resend.dev"

# ─── Admin ────────────────────────────────────────────────────────────────────

# Initial admin account (created by the seed script)
ADMIN_EMAIL="admin@linked-me.com"
ADMIN_PASSWORD="change-me"

# ─── Maintenance ──────────────────────────────────────────────────────────────

# Lifetime in hours before unverified accounts are automatically deleted (optional, default: 24)
UNVERIFIED_USER_TTL_HOURS=24

# Audit log retention in days (optional, default: 30)
AUDIT_LOG_TTL_DAYS=30
